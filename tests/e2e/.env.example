# Copy to .env and fill in passwords for your Docker Nextcloud dev instance.
# Users must exist and have ArbeitszeitCheck access (see occ user:list).
# Substitute workflow E2E needs vacation balance for e2e_employee.
# `./scripts/run-e2e-docker.sh` runs `seed-e2e-vacation-docker.sh` (occ ensure-e2e-vacation).
# Or manually: docker compose exec nextcloud php occ arbeitszeitcheck:ensure-e2e-vacation e2e_employee --force

NC_BASE_URL=http://localhost:8081

NC_EMPLOYEE_USER=e2e_employee
NC_EMPLOYEE_PASS=

NC_MANAGER_USER=e2e_manager
NC_MANAGER_PASS=

NC_SUBSTITUTE_USER=e2e_substitute
NC_SUBSTITUTE_PASS=
